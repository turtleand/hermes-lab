---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const topics = (await getCollection('topics', ({ data }) => !data.draft)).sort((a, b) =>
  a.data.title.localeCompare(b.data.title)
);

const modules = [
  {
    id: 0,
    code: 'M0',
    title: 'Setup & Voice',
    fullTitle: 'Module 0: Setup & Voice',
    description: 'Gateway, Telegram, voice, and update routines that make Hermes dependable in daily use.',
    intent: 'Get the operating layer right before scaling the assistant.',
    topics: topics.filter(t => t.data.module === 'Module 0: Setup & Voice'),
  },
  {
    id: 1,
    code: 'M1',
    title: 'Foundations',
    fullTitle: 'Module 1: Foundations',
    description: 'Core patterns for using Hermes as a serious reasoning companion.',
    intent: 'Turn repeated use into reusable operating principles.',
    topics: topics.filter(t => t.data.module === 'Module 1: Foundations'),
  },
];

function getStatusMeta(status: string) {
  switch (status) {
    case 'done': return { label: 'Verified note', icon: '✓', class: 'status-done' };
    case 'in-progress': return { label: 'In progress', icon: '◐', class: 'status-in-progress' };
    default: return { label: 'Planned', icon: '○', class: 'status-planned' };
  }
}

function shortModule(module: string) {
  return module.replace(/^Module \d+:\s*/, '');
}
---

<BaseLayout title="Home">
  <section class="hero-shell blog-hero" aria-labelledby="hero-title">
    <div class="container blog-hero__grid">
      <div class="hero-copy">
        <p class="eyebrow">Turtleand Hermes Lab</p>
        <h1 id="hero-title">A field notebook for living with Hermes.</h1>
        <p class="hero-lede">
          These are practical notes from running Hermes as a real assistant: what broke, what helped, what became a habit, and what is safe to share publicly.
        </p>
        <p class="hero-note">
          This is a record, not a pitch: small operating details, tested in use, written down before they disappear into habit.
        </p>
      </div>

      <aside class="desk-note" aria-label="Hermes Lab editorial note">
        <p class="desk-note__kicker">from the desk</p>
        <p>
          I use Hermes as a thinking partner, build companion, news filter, and maintenance layer. When a pattern survives real use, it becomes a note here.
        </p>
        <p>
          Private infrastructure stays private. Public lessons stay reusable.
        </p>
      </aside>
    </div>
  </section>

  <section class="field-notes-section" id="field-notes" aria-labelledby="field-notes-title">
    <div class="container notebook-layout">
      <div class="section-heading notebook-intro">
        <p class="eyebrow">Latest notes</p>
        <h2 id="field-notes-title">A blog of operational lessons.</h2>
        <p>
          Each note starts with a specific Hermes friction point, then compresses the lesson into something another operator can inspect, adapt, or avoid.
        </p>
      </div>

      <div class="post-list" aria-label="Published field notes">
        {topics.map((topic) => {
          const status = getStatusMeta(topic.data.status);
          return (
            <article class="post-row">
              <a href={`/topics/${topic.id}`} class="post-row__link no-underline">
                <div class="post-row__meta">
                  <span>{shortModule(topic.data.module)}</span>
                  <span class={status.class}>{status.icon} {status.label}</span>
                </div>
                <h3>{topic.data.title}</h3>
                <p>{topic.data.summary}</p>
                <span class="post-row__read">Continue reading</span>
              </a>
            </article>
          );
        })}
      </div>

      <aside class="thread-index" aria-label="Notebook threads">
        <p class="thread-index__title">Notebook threads</p>
        {modules.map((module) => (
          <section class="thread-index__item" aria-labelledby={`module-${module.id}`}>
            <span>{module.code}</span>
            <div>
              <h3 id={`module-${module.id}`}>{module.title}</h3>
              <p>{module.description}</p>
              <small>{module.topics.length} {module.topics.length === 1 ? 'note' : 'notes'}</small>
            </div>
          </section>
        ))}
      </aside>
    </div>
  </section>
</BaseLayout>
