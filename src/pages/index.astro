---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const topics = (await getCollection('topics', ({ data }) => !data.draft)).sort((a, b) =>
  a.data.title.localeCompare(b.data.title)
);

const modules = [
  {
    id: 0,
    code: 'M0',
    title: 'Setup & Voice',
    fullTitle: 'Module 0: Setup & Voice',
    description: 'Gateway, Telegram, voice, and update routines that make Hermes dependable in daily use.',
    intent: 'Get the operating layer right before scaling the assistant.',
    topics: topics.filter(t => t.data.module === 'Module 0: Setup & Voice'),
  },
  {
    id: 1,
    code: 'M1',
    title: 'Foundations',
    fullTitle: 'Module 1: Foundations',
    description: 'Core patterns for using Hermes as a serious reasoning companion.',
    intent: 'Turn repeated use into reusable operating principles.',
    topics: topics.filter(t => t.data.module === 'Module 1: Foundations'),
  },
];

const publishedCount = topics.length;
const completeCount = topics.filter(topic => topic.data.status === 'done').length;
const moduleCount = modules.length;

function getStatusMeta(status: string) {
  switch (status) {
    case 'done': return { label: 'Verified note', icon: '✓', class: 'status-done' };
    case 'in-progress': return { label: 'In progress', icon: '◐', class: 'status-in-progress' };
    default: return { label: 'Planned', icon: '○', class: 'status-planned' };
  }
}
---

<BaseLayout title="Home">
  <section class="hero-shell" aria-labelledby="hero-title">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Hermes Lab · operational field notes</p>
        <h1 id="hero-title">Field notes for making Hermes reliable.</h1>
        <p class="hero-lede">
          Practical notes on gateway health, Telegram workflows, voice delivery, skills, scheduling, and the small checks that make an agent feel dependable.
        </p>
        <div class="hero-actions" aria-label="Primary actions">
          <a class="button-primary" href="#field-notes">Read the notes</a>
          <a class="button-secondary" href="/llms.txt">Open llms.txt</a>
        </div>
      </div>

      <aside class="ops-panel" aria-label="Hermes Lab operating snapshot">
        <div class="ops-panel__header">
          <span class="terminal-dot terminal-dot--green"></span>
          <span class="terminal-dot terminal-dot--amber"></span>
          <span class="terminal-dot terminal-dot--blue"></span>
          <span class="ops-panel__label">public proof check</span>
        </div>
        <dl class="ops-stats">
          <div>
            <dt>Published notes</dt>
            <dd>{publishedCount}</dd>
          </div>
          <div>
            <dt>Complete</dt>
            <dd>{completeCount}</dd>
          </div>
          <div>
            <dt>Modules</dt>
            <dd>{moduleCount}</dd>
          </div>
        </dl>
        <div class="log-lines" aria-label="Example verification flow">
          <p><span>$</span> hermes gateway status</p>
          <p><span>✓</span> verify from outside the chat session</p>
          <p><span>✓</span> document the reusable lesson</p>
          <p><span>→</span> publish only the safe pattern</p>
        </div>
      </aside>
    </div>
  </section>

  <section class="field-notes-section" id="field-notes" aria-labelledby="field-notes-title">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Curriculum spine</p>
        <h2 id="field-notes-title">A small operating library, built from real use.</h2>
        <p>
          Hermes Lab keeps the useful pattern and leaves private infrastructure out of view. Each note should help another operator reason, verify, or recover faster.
        </p>
      </div>

      <div class="module-stack">
        {modules.map((module) => (
          <section class="module-panel" aria-labelledby={`module-${module.id}`}>
            <div class="module-panel__rail" aria-hidden="true">
              <span>{module.code}</span>
            </div>
            <div class="module-panel__body">
              <div class="module-panel__header">
                <div>
                  <p class="module-kicker">{module.fullTitle}</p>
                  <h3 id={`module-${module.id}`}>{module.title}</h3>
                  <p>{module.description}</p>
                </div>
                <div class="module-count">
                  <strong>{module.topics.length}</strong>
                  <span>{module.topics.length === 1 ? 'note' : 'notes'}</span>
                </div>
              </div>

              <p class="module-intent">{module.intent}</p>

              {module.topics.length > 0 ? (
                <div class="topic-grid">
                  {module.topics.map((topic) => {
                    const status = getStatusMeta(topic.data.status);
                    return (
                      <a href={`/topics/${topic.id}`} class="topic-card no-underline">
                        <div class="topic-card__status">
                          <span class={status.class}>{status.icon}</span>
                          <span>{status.label}</span>
                        </div>
                        <h4>{topic.data.title}</h4>
                        <p>{topic.data.summary}</p>
                        <span class="topic-card__cta">Read field note</span>
                      </a>
                    );
                  })}
                </div>
              ) : (
                <div class="empty-panel">
                  <span>Queued</span>
                  <p>Foundation notes will appear here once they clear the same verification and public-safety loop.</p>
                </div>
              )}
            </div>
          </section>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
