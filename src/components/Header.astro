---
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/#field-notes', label: 'Notes' },
];

const currentPath = Astro.url.pathname;

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  if (href === '/#field-notes') return currentPath.startsWith('/topics');
  return currentPath === href || currentPath.startsWith(href);
}
---

<header class="site-header">
  <div class="container site-header__inner">
    <a href="/" class="brand-mark no-underline" aria-label="Turtleand Hermes Lab home">
      <img src="/logo.svg" alt="" class="brand-mark__logo" loading="lazy" decoding="async" />
      <span class="brand-mark__text">
        <strong>Turtleand Hermes</strong>
        <span>Lab</span>
      </span>
    </a>

    <nav class="site-nav" aria-label="Primary navigation">
      {navItems.map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            'site-nav__link no-underline',
            isActive(href) ? 'site-nav__link--active' : ''
          ]}
        >
          {label}
        </a>
      ))}

      <button id="theme-toggle" class="theme-toggle" aria-label="Toggle theme">
        <svg class="w-5 h-5 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
        <svg class="w-5 h-5 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
      </button>
    </nav>
  </div>
</header>
