---
const year = new Date().getFullYear();

const links = [
  { href: 'https://github.com/turtleand', label: 'GitHub' },
  { href: 'https://turtleand.com', label: 'turtleand.com' },
];
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <div>
      <p class="site-footer__title">Turtleand Hermes Lab</p>
      <p class="site-footer__meta">&copy; {year} Turtleand. Public lessons, private details removed.</p>
    </div>
    <div class="site-footer__links">
      {links.map(({ href, label }) => (
        <a href={href} class="utility-link no-underline">{label}</a>
      ))}
    </div>
  </div>
</footer>
